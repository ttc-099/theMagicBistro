<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<!-- stack pane centers everything -->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.files.projBistro.models.controllers.LoginController">

    <!-- main vertical box containing all login elements -->
    <VBox alignment="CENTER" spacing="15"
          maxWidth="380" maxHeight="550"
          styleClass="login-card" style="-fx-padding: 30;">

        <!-- logo icon - centered -->
        <ImageView fitHeight="100" fitWidth="100" preserveRatio="true">
            <Image url="@/main_icon.png" />
        </ImageView>

        <!-- restaurant name -->
        <Label text="CAMO-GEAR BISTRO" styleClass="bold-text"
               style="-fx-font-size: 22px; -fx-font-weight: bold;" alignment="CENTER"/>

        <!-- subtitle -->
        <Label text="Admin and Customer Portal" styleClass="muted-text"
               style="-fx-font-size: 12px;" alignment="CENTER"/>

        <Separator prefWidth="280"/>

        <!-- username input field -->
        <TextField fx:id="usernameField" promptText="Username"
                   prefWidth="280" maxWidth="280"/>

        <!-- password input field -->
        <PasswordField fx:id="passwordField" promptText="Password"
                       prefWidth="280" maxWidth="280"/>

        <!-- login button -->
        <Button fx:id="loginBtn" text="LOGIN" onAction="#handleLogin"
                prefWidth="280" maxWidth="280" styleClass="login-button"
                onMouseEntered="#onLoginButtonHover"
                onMouseExited="#onLoginButtonExit"/>

        <!-- link to registration screen -->
        <Hyperlink text="New recruit? Register here" onAction="#handleShowRegister"
                   styleClass="muted-text" style="-fx-font-size: 12px;"/>

        <!-- error message label -->
        <Label fx:id="errorLabel" styleClass="status-error"
               style="-fx-font-size: 12px;" wrapText="true" alignment="CENTER" maxWidth="280"/>

        <!-- footer copyright text -->
        <Label text="Camo-Gear Bistro © 2026"
               styleClass="status-muted" style="-fx-font-size: 10px;"/>

    </VBox>
</StackPane>