<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<!--
  this is the login screen
  users enter username and password to log in
  controller: logincontroller.java
-->

<!-- stack pane centers everything -->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.files.projBistro.models.controllers.LoginController">

    <!-- main vertical box containing all login elements -->
    <VBox alignment="CENTER" spacing="20"
          maxWidth="350" maxHeight="450"
          styleClass="item-card" style="-fx-padding: 30;">

        <!-- logo icon -->
        <Label text="🍽️" style="-fx-font-size: 64;"/>

        <!-- restaurant name -->
        <Label text="CAMO-GEAR BISTRO" styleClass="bold-text" style="-fx-font-size: 20;"/>

        <!-- subtitle -->
        <Label text="Admin and Customer Portal" styleClass="muted-text" style="-fx-font-size: 12;"/>

        <Separator prefWidth="250"/>

        <!-- username input field -->
        <TextField fx:id="usernameField" promptText="Username"
                   prefWidth="250" maxWidth="250"/>

        <!-- password input field (characters are hidden) -->
        <PasswordField fx:id="passwordField" promptText="Password"
                       prefWidth="250" maxWidth="250"/>

        <!-- login button -->
        <Button fx:id="loginBtn" text="LOGIN" onAction="#handleLogin"
                prefWidth="250" maxWidth="250" styleClass="login-button"
                onMouseEntered="#onLoginButtonHover"
                onMouseExited="#onLoginButtonExit"/>

        <!-- link to registration screen -->
        <Hyperlink text="New recruit? Register here" onAction="#handleShowRegister"
                   styleClass="muted-text" style="-fx-font-size: 12;"/>

        <!-- error message label (shows when login fails) -->
        <Label fx:id="errorLabel" styleClass="status-error" style="-fx-font-size: 12;" wrapText="true" alignment="CENTER"/>

        <!-- footer copyright text -->
        <Label text="Camo-Gear Bistro © 2026"
               styleClass="status-muted" style="-fx-font-size: 10;"/>

    </VBox>
</StackPane>