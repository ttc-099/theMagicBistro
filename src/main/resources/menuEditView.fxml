<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.shape.Rectangle?>
<VBox spacing="15" prefHeight="700.0" prefWidth="1024.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.files.projBistro.models.controllers.MenuEditController">

    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header-bar" style="-fx-padding: 15;">
        <Label text="MENU MANAGEMENT SYSTEM" styleClass="bold-text" style="-fx-font-size: 22;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="statusLabel" text="Ready." styleClass="status-muted" style="-fx-padding: 5;"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Filter by Character:" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
        <ToggleButton fx:id="chloeFilter" text="Chloe" onAction="#filterByChloe" />
        <ToggleButton fx:id="mimiFilter" text="Mimi" onAction="#filterByMimi" />
        <ToggleButton fx:id="metsuFilter" text="Metsu" onAction="#filterByMetsu" />
        <ToggleButton fx:id="laniardFilter" text="Laniard" onAction="#filterByLaniard" />
        <ToggleButton fx:id="allFilter" text="All Items" onAction="#filterAll" />

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="Refresh" onAction="#refreshTable" />
    </HBox>

    <SplitPane dividerPositions="0.55" VBox.vgrow="ALWAYS">

        <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: white;">
            <Label text="Current Menu Items" style="-fx-text-fill: #333; -fx-font-weight: bold; -fx-font-size: 14;"/>

            <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50" resizable="false"/>
                    <TableColumn fx:id="colName" text="Item Name" prefWidth="180"/>
                    <TableColumn fx:id="colPrice" text="Price (RM)" prefWidth="80"/>
                    <TableColumn fx:id="colStock" text="Stock" prefWidth="70"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="80"/>
                    <TableColumn fx:id="colCharacter" text="Character" prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="No items found. Add some!" style="-fx-text-fill: gray;"/>
                </placeholder>
            </TableView>

            <HBox spacing="10">
                <Label text="Total Items: " style="-fx-text-fill: black;"/>
                <Label fx:id="itemCountLabel" text="0" style="-fx-text-fill: #333; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>

        <VBox spacing="15" style="-fx-padding: 10; -fx-background-color: white;">

            <Label text="Item Editor" style="-fx-text-fill: #333; -fx-font-weight: bold; -fx-font-size: 14;"/>

            <Separator />

            <StackPane fx:id="editorStackPane">
                <!-- The actual editor content -->
                <VBox spacing="15">
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="Item Image" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                        <StackPane fx:id="imageContainer" style="-fx-border-color: #ddd; -fx-border-width: 1; -fx-background-color: #f8f9fa;"
                                   prefHeight="150" prefWidth="150">
                            <ImageView fx:id="imagePreview" fitHeight="140" fitWidth="140" preserveRatio="true" />
                        </StackPane>
                        <Button fx:id="chooseImageBtn" text="Choose Image" onAction="#handleChooseImage" />
                    </VBox>

                    <Separator />

                    <GridPane hgap="10" vgap="12">
                        <Label text="Item Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                        <TextField fx:id="nameInput" promptText="Item Name" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>

                        <Label text="Price (RM):" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                        <TextField fx:id="priceInput" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Stock:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                        <TextField fx:id="stockInput" promptText="0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Item Type:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="typeBox" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="Select type" prefWidth="150" />

                        <Label text="Character:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="characterBox" GridPane.columnIndex="1" GridPane.rowIndex="4" promptText="Select character" prefWidth="150" />

                        <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                        <TextArea fx:id="descriptionInput" promptText="Description..." GridPane.columnIndex="1" GridPane.rowIndex="5"
                                  prefHeight="60" wrapText="true" />
                    </GridPane>

                    <Separator />

                    <HBox spacing="10" alignment="CENTER">
                        <Button fx:id="addBtn" text="Add New" onAction="#handleAddItem" prefWidth="120"/>
                        <Button fx:id="updateBtn" text="Update" onAction="#handleEditItem" prefWidth="120"/>
                        <Button fx:id="deleteBtn" text="Delete" onAction="#handleRemoveItem" prefWidth="120"/>
                        <Button fx:id="clearBtn" text="Clear" onAction="#clearForm" prefWidth="120"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER">
                        <Button fx:id="backBtn" text="Back to Dashboard" onAction="#handleBack" prefWidth="200"/>
                    </HBox>
                </VBox>

            </StackPane>

            <Label fx:id="selectionHint" text="Select an item from the table to edit"
                   style="-fx-text-fill: #f39c12; -fx-font-size: 11px; -fx-font-style: italic;"
                   alignment="CENTER" maxWidth="Infinity" visible="false"/>
        </VBox>
    </SplitPane>
</VBox>