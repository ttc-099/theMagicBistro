<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.files.projBistro.models.controllers.OrderHistoryController"
      styleClass="order-history-root">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <!-- Header with Back Button -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="← Back to Menu" onAction="#handleBackToMenu" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 5;" />
        <Label text="📜 ORDER HISTORY" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Refresh" onAction="#loadOrderHistory" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
    </HBox>

    <Separator />

    <!-- Ordered Items Section -->
    <Label fx:id="statusLabel" text="Loading your order history..." style="-fx-text-fill: #666; -fx-font-size: 12px;" />

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <TilePane fx:id="itemsTilePane" hgap="20" vgap="20" prefColumns="3"
                  style="-fx-background-color: transparent; -fx-padding: 10;" />
    </ScrollPane>

</VBox>