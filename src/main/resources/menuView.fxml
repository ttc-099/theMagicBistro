<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1024.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.files.projBistro.models.controllers.MenuController"
            styleClass="main-root">

    <padding>
        <Insets bottom="16" left="16" right="16" top="16" />
    </padding>

    <top>
        <VBox spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <padding>
                    <Insets bottom="1" left="15" right="15" top="10" />
                </padding>
                <Label text="CAMO-GEAR BISTRO" styleClass="title-label" />
                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="orderHistoryBtn" onAction="#handleOrderHistory" text="Order History" styleClass="settings-button" />
                <Button fx:id="settingsBtn" onAction="#handleOpenSettings" text="Settings" styleClass="settings-button" />
                <Button fx:id="authBtn" onAction="#handleAuthAction" text="Login" styleClass="auth-button" />
            </HBox>

            <HBox alignment="CENTER_LEFT">
                <padding>
                    <Insets bottom="5" left="15" right="15" top="3" />
                </padding>
                <Label fx:id="welcomeLabel" text="Welcome, Guest!" styleClass="welcome-label" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="mainContentArea">
            <VBox fx:id="menuView" VBox.vgrow="ALWAYS">
                <TabPane fx:id="categoryTabs" prefHeight="573.0" prefWidth="692.0" tabClosingPolicy="UNAVAILABLE" styleClass="menu-tabpane">
                    <BorderPane.margin>
                        <Insets top="8.0" />
                    </BorderPane.margin>
                </TabPane>
            </VBox>
        </StackPane>
    </center>

    <right>
        <VBox prefWidth="300" spacing="18" styleClass="order-sidebar">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>

            <Label text="YOUR ORDER" styleClass="order-title" />
            <Separator styleClass="custom-separator" />
            <ListView fx:id="cartListView" VBox.vgrow="ALWAYS" styleClass="cart-listview">
                <placeholder>
                    <Label text="Your cart is empty." styleClass="empty-cart-label" />
                </placeholder>
            </ListView>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </padding>
                <ImageView fx:id="characterImageView" fitHeight="70.0" fitWidth="70.0" pickOnBounds="true" preserveRatio="true">
                    <Image url="@icons/ic_Chloe/icon_chloe.png" />
                </ImageView>
                <VBox spacing="5" styleClass="dialogue-bubble" HBox.hgrow="ALWAYS">
                    <Label fx:id="dialogueLabel" text="Please select an item to start." wrapText="true" styleClass="dialogue-text" />
                </VBox>
            </HBox>

            <Separator styleClass="custom-separator" />
            <Label fx:id="totalLabel" text="Total: 0.00" styleClass="total-label" />
            <Button fx:id="submitBtn" onAction="#handleSubmitOrder" prefHeight="40" prefWidth="270" text="SUBMIT ORDER" styleClass="submit-button" />
            <Button onAction="#handleClearCart" prefHeight="35" prefWidth="270" text="Clear Cart" styleClass="clear-cart-button" />
        </VBox>
    </right>
</BorderPane>