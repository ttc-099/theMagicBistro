<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?> <!-- -->
<?import javafx.scene.layout.*?> <!-- -->
<?import javafx.scene.image.*?> <!-- -->
<?import javafx.geometry.Insets?> <!-- -->

<!-- -->
<BorderPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.files.projBistro.controllers.MenuController">

    <!-- banner -->
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10;">
            <Label text="Camo-Gear Bistro Menu" style="-fx-font-size: 24; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" /> <Button text="⛯ Settings" fx:id="settingsBtn" />
        </HBox>
    </top>

    <!-- main pane -->
    <center>
        <VBox spacing="10">
            <TabPane fx:id="categoryTabs" tabClosingPolicy="UNAVAILABLE">
                <!-- sub-tabs -->
                <tabs>
                    <!-- chloe -->
                    <Tab text="Chloe">
                        <ScrollPane fitToWidth="true" prefHeight="450.0">
                            <TilePane fx:id="chloeGrid" hgap="20" vgap="20" prefColumns="3">
                                <padding>
                                    <Insets top="20" right="20" bottom="20" left="20"/>
                                </padding>
                            </TilePane>
                        </ScrollPane>
                    </Tab>

                    <!-- mimi -->
                    <Tab text="Mimi" />

                    <!-- metsu -->
                    <Tab text="Metsu" />

                    <!--  -->
                    <Tab text="Laniard" />

                </tabs>
            </TabPane>

            <!-- add to order button -->
            <HBox alignment="CENTER" style="-fx-padding: 10;">
                <Button text="Add to Order" onAction="#handleAddItem" prefWidth="150" />
            </HBox>

        </VBox>
    </center>

    <right>

        <!-- setting -->
        <VBox spacing="15" prefWidth="250" alignment="TOP_CENTER"
              style="-fx-border-color: #cccccc; -fx-border-width: 0 0 0 1; -fx-padding: 15;">

            <!-- template, replace for png -->
            <StackPane style="-fx-border-color: red; -fx-border-width: 2;">
                <ImageView fx:id="characterPortrait" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
                </ImageView>
            </StackPane>

            <!-- dialogue box, replace for image  -->
            <Label text="Dialog area..." style="-fx-font-style: italic; -fx-border-color: purple;" />

            <!-- cart list for added items, dynamically grow -->
            <VBox VBox.vgrow="ALWAYS" spacing="5">
                <Label text="Your Cart" style="-fx-font-weight: bold;" />
                <ListView fx:id="cartListView" VBox.vgrow="ALWAYS" />
            </VBox>

            <!-- total -->
            <Label fx:id="totalLabel" text="Total: £0.00" style="-fx-font-size: 18;" />
            <Button text="Submit Order" fx:id="submitBtn" prefWidth="200" style="-fx-font-size: 16;" />
        </VBox>

    </right>

</BorderPane>