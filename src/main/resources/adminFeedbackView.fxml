<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.files.projBistro.models.controllers.admin.AdminFeedbackController"
      style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15" />
    </padding>

    <!-- Header with title and info icon -->
    <Label text="📊 FEEDBACK &amp; CUSTOMER LOYALTY" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <Separator />

    <!-- Stats Cards Row -->
    <HBox spacing="20" alignment="CENTER">
        <VBox alignment="CENTER" spacing="5" prefWidth="180"
              style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 10; -fx-background-radius: 10;">
            <Label text="⭐ Average Rating" style="-fx-text-fill: #666;" />
            <Label fx:id="avgRatingLabel" text="0.0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
        </VBox>

        <VBox alignment="CENTER" spacing="5" prefWidth="180"
              style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 10; -fx-background-radius: 10;">
            <Label text="📝 Total Responses" style="-fx-text-fill: #666;" />
            <Label fx:id="totalResponsesLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
        </VBox>

        <VBox alignment="CENTER" spacing="5" prefWidth="180"
              style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 10; -fx-background-radius: 10;">
            <Label text="📊 Response Rate" style="-fx-text-fill: #666;" />
            <Label fx:id="responseRateLabel" text="0%" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
        </VBox>
    </HBox>

    <Separator />

    <!-- Customer Loyalty Table -->
    <Label text="👥 CUSTOMER LOYALTY" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
    <TableView fx:id="loyaltyTable" prefHeight="200" VBox.vgrow="NEVER">
        <columns>
            <TableColumn fx:id="colUsername" text="Username" prefWidth="150" />
            <TableColumn fx:id="colTotalOrders" text="Orders" prefWidth="80" />
            <TableColumn fx:id="colTotalSpent" text="Total Spent (RM)" prefWidth="120" />
            <TableColumn fx:id="colPhoneNumber" text="Phone Number" prefWidth="150" />
            <TableColumn fx:id="colLastOrder" text="Last Order" prefWidth="150" />
        </columns>
    </TableView>

    <Separator />

    <!-- Feedback Table with Filter Row -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="💬 FEEDBACK ENTRIES" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="Filter by:" style="-fx-text-fill: #666;" />
        <ComboBox fx:id="ratingFilter" prefWidth="100" promptText="Rating" />
        <DatePicker fx:id="startDateFilter" promptText="From Date" />
        <DatePicker fx:id="endDateFilter" promptText="To Date" />
        <Button text="Apply Filters" onAction="#handleApplyFilters" />
        <Button text="Reset" onAction="#handleResetFilters" />
    </HBox>

    <TableView fx:id="feedbackTable" prefHeight="250" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colOrderId" text="Order #" prefWidth="80" />
            <TableColumn fx:id="colCustomerName" text="Customer" prefWidth="150" />
            <TableColumn fx:id="colFeedbackDate" text="Date" prefWidth="150" />
            <TableColumn fx:id="colRatingStars" text="Rating" prefWidth="100" />
            <TableColumn fx:id="colCommentPreview" text="Comment Preview" prefWidth="300" />
        </columns>
    </TableView>

    <Separator />

    <Label text="📖 FULL FEEDBACK DETAILS" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
    <Label text="(Click any row in the table above to view full details)" style="-fx-text-fill: #666; -fx-font-size: 11px;" />
    <ScrollPane fx:id="detailScrollPane" prefHeight="150" VBox.vgrow="ALWAYS"
                style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 8;">
        <VBox fx:id="detailsContent" spacing="10" style="-fx-padding: 15;">
            <!-- Dynamic content appears here when row is clicked -->
            <Label text="Select a feedback entry to view details." style="-fx-text-fill: #999; -fx-font-style: italic;" />
        </VBox>
    </ScrollPane>

</VBox>